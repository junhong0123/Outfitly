@model List<Outfitly.Models.CartItem>
@{
    ViewData["Title"] = "Shopping Cart";
    var cart = new Outfitly.Models.Cart { Items = Model ?? new List<Outfitly.Models.CartItem>() };
}

<!-- Page Header -->
<div class="bg-white border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <h1 class="text-3xl md:text-4xl font-light text-black">Shopping Cart</h1>
    </div>
</div>

@if (Model != null && Model.Any())
{
<!-- Cart Content -->
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-12">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

        <!-- Left Column: Cart Items -->
        <div class="lg:col-span-2 space-y-4">

            @foreach (var item in Model)
            {
            <!-- Cart Item -->
            <div class="cart-item bg-white border border-gray-200 rounded p-4 flex gap-4" data-item-id="@item.Id" data-price="@item.Price">
                <!-- Product Image -->
                <div class="w-24 h-24 bg-gray-100 rounded flex-shrink-0 flex items-center justify-center overflow-hidden">
                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                    {
                        <img src="@item.ImageUrl" alt="@item.ProductName" class="w-full h-full object-cover" />
                    }
                    else
                    {
                        <span class="text-gray-400 text-xs">Image</span>
                    }
                </div>

                <!-- Product Details -->
                <div class="flex-grow">
                    <div class="flex justify-between items-start mb-2">
                        <div>
                            <h3 class="text-sm font-medium text-black mb-1">@item.ProductName</h3>
                            <p class="text-xs text-gray-600">Color: @(item.Color ?? "N/A")</p>
                            <p class="text-xs text-gray-600">Size: @(item.Size ?? "N/A")</p>
                        </div>
                        <button class="remove-item text-gray-400 hover:text-black transition" data-item-id="@item.Id">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                            </svg>
                        </button>
                    </div>

                    <div class="flex justify-between items-center mt-3">
                        <!-- Quantity Controls -->
                        <div class="flex items-center border border-gray-300 rounded">
                            <button class="decrease-qty px-3 py-1 hover:bg-gray-100 transition" data-item-id="@item.Id">-</button>
                            <input type="number" value="@item.Quantity" min="1" class="quantity-input w-12 text-center border-x border-gray-300 py-1 text-sm focus:outline-none" data-item-id="@item.Id">
                            <button class="increase-qty px-3 py-1 hover:bg-gray-100 transition" data-item-id="@item.Id">+</button>
                        </div>

                        <!-- Price -->
                        <p class="text-sm font-medium text-black item-total">$@item.TotalPrice.ToString("F2")</p>
                    </div>
                </div>
            </div>
            }

            <!-- Continue Shopping Link -->
            <div class="pt-4">
                <a asp-area="" asp-controller="Products" asp-action="Index"
                   class="inline-flex items-center text-sm text-gray-700 hover:text-black transition">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                    </svg>
                    Continue Shopping
                </a>
            </div>
        </div>

        <!-- Right Column: Order Summary -->
        <div class="lg:col-span-1">
            <div id="orderSummary" class="bg-white border border-gray-200 rounded p-6 sticky top-24"
                 data-free-shipping-threshold="100"
                 data-shipping-cost="10"
                 data-tax-rate="0.10">
                <h2 class="text-lg font-medium text-black mb-6">Order Summary</h2>

                <!-- Summary Details -->
                <div class="space-y-3 mb-6">
                    <div class="flex justify-between text-sm">
                        <span class="text-gray-600">Subtotal (@cart.TotalItems items)</span>
                        <span class="text-black font-medium" id="subtotal">$@cart.Subtotal.ToString("F2")</span>
                    </div>
                    <div class="flex justify-between text-sm">
                        <span class="text-gray-600">Shipping</span>
                        <span class="text-black font-medium" id="shipping">$@cart.Shipping.ToString("F2")</span>
                    </div>
                    <div class="flex justify-between text-sm">
                        <span class="text-gray-600">Tax</span>
                        <span class="text-black font-medium" id="tax">$@cart.Tax.ToString("F2")</span>
                    </div>
                </div>

                <!-- Promo Code -->
                <div class="mb-6 pb-6 border-t border-b border-gray-200 py-6">
                    <label class="text-xs font-medium text-black mb-2 block tracking-wide">PROMO CODE</label>
                    <div class="flex gap-2">
                        <input type="text" placeholder="Enter code" id="promoCodeInput"
                               class="flex-grow text-sm border border-gray-300 rounded px-3 py-2 focus:outline-none focus:border-black">
                        <button id="applyPromoBtn" class="bg-gray-100 text-black px-4 py-2 text-sm hover:bg-gray-200 transition rounded">
                            Apply
                        </button>
                    </div>
                </div>

                <!-- Total -->
                <div class="flex justify-between items-center mb-6">
                    <span class="text-base font-medium text-black">Total</span>
                    <span class="text-2xl font-light text-black" id="total">$@cart.Total.ToString("F2")</span>
                </div>

                <!-- Checkout Button -->
                <a asp-area="" asp-controller="Checkout" asp-action="Index"
                   class="block w-full bg-black text-white text-center py-4 text-sm tracking-wide hover:bg-gray-800 transition rounded mb-3">
                    PROCEED TO CHECKOUT
                </a>

                <!-- Payment Methods -->
                <div class="text-center">
                    <p class="text-xs text-gray-500 mb-2">We accept</p>
                    <div class="flex justify-center gap-2">
                        <div class="w-10 h-6 bg-gray-200 rounded flex items-center justify-center">
                            <span class="text-xs text-gray-500">VISA</span>
                        </div>
                        <div class="w-10 h-6 bg-gray-200 rounded flex items-center justify-center">
                            <span class="text-xs text-gray-500">MC</span>
                        </div>
                        <div class="w-10 h-6 bg-gray-200 rounded flex items-center justify-center">
                            <span class="text-xs text-gray-500">AMEX</span>
                        </div>
                    </div>
                </div>

                @if (cart.Subtotal < 100)
                {
                <!-- Free Shipping Notice -->
                <div class="mt-6 bg-amber-50 border border-amber-200 rounded p-4">
                    <div class="flex items-start gap-2">
                        <svg class="w-5 h-5 text-amber-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        <p class="text-xs text-amber-800">
                            Add <strong>$@((100 - cart.Subtotal).ToString("F2"))</strong> more to get free shipping!
                        </p>
                    </div>
                </div>
                }
            </div>
        </div>
    </div>
</div>
}
else
{
<!-- Empty Cart State -->
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 text-center">
    <svg class="w-24 h-24 mx-auto text-gray-300 mb-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
    </svg>
    <h2 class="text-2xl font-light text-black mb-3">Your cart is empty</h2>
    <p class="text-sm text-gray-600 mb-8">Discover our curated collection and find your perfect style</p>
    <a asp-area="" asp-controller="Products" asp-action="Index"
       class="inline-block bg-black text-white px-8 py-3 text-sm tracking-wide hover:bg-gray-800 transition">
        START SHOPPING
    </a>
</div>
}

@section Scripts {
    <script>
        // ── Configurable values from data-* attributes ──
        const summaryEl = document.getElementById('orderSummary');
        const FREE_SHIPPING_THRESHOLD = parseFloat(summaryEl?.dataset.freeShippingThreshold ?? '100');
        const SHIPPING_COST = parseFloat(summaryEl?.dataset.shippingCost ?? '10');
        const TAX_RATE = parseFloat(summaryEl?.dataset.taxRate ?? '0.10');

        let promoDiscount = 0;

        // ── Helper: sync quantity to server ──
        async function syncCartItem(cartItemId, quantity) {
            try {
                const res = await fetch('/Cart/Update', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: `cartItemId=${cartItemId}&quantity=${quantity}`
                });
                const data = await res.json();
                if (!data.success) console.warn('Cart update failed:', data.message);
                return data.success;
            } catch (err) {
                console.error('Cart sync error:', err);
                return false;
            }
        }

        // ── Helper: remove item from server ──
        async function removeCartItem(cartItemId) {
            try {
                const res = await fetch('/Cart/Remove', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: `cartItemId=${cartItemId}`
                });
                const data = await res.json();
                return data.success;
            } catch (err) {
                console.error('Cart remove error:', err);
                return false;
            }
        }

        // ── Update totals from DOM ──
        function updateCartTotals() {
            let subtotal = 0;
            let totalItems = 0;

            document.querySelectorAll('.cart-item').forEach(el => {
                const price = parseFloat(el.dataset.price);
                const qty = parseInt(el.querySelector('.quantity-input').value) || 0;
                const itemTotal = price * qty;
                subtotal += itemTotal;
                totalItems += qty;

                // Update per-item total
                el.querySelector('.item-total').textContent = '$' + itemTotal.toFixed(2);
            });

            const shipping = subtotal >= FREE_SHIPPING_THRESHOLD ? 0 : SHIPPING_COST;
            const tax = subtotal * TAX_RATE;
            const total = subtotal + shipping + tax - promoDiscount;

            document.getElementById('subtotal').textContent = '$' + subtotal.toFixed(2);
            document.getElementById('shipping').textContent = '$' + shipping.toFixed(2);
            document.getElementById('tax').textContent = '$' + tax.toFixed(2);
            document.getElementById('total').textContent = '$' + Math.max(0, total).toFixed(2);

            // Update free-shipping notice
            const freeShipNotice = document.querySelector('.bg-amber-50');
            if (freeShipNotice) {
                if (subtotal >= FREE_SHIPPING_THRESHOLD) {
                    freeShipNotice.classList.add('hidden');
                } else {
                    freeShipNotice.classList.remove('hidden');
                    const diff = (FREE_SHIPPING_THRESHOLD - subtotal).toFixed(2);
                    freeShipNotice.querySelector('p').innerHTML =
                        `Add <strong>$${diff}</strong> more to get free shipping!`;
                }
            }
        }

        // ── Quantity increase ──
        document.querySelectorAll('.increase-qty').forEach(btn => {
            btn.addEventListener('click', async function () {
                const itemEl = this.closest('.cart-item');
                const input = itemEl.querySelector('.quantity-input');
                const newQty = parseInt(input.value) + 1;
                const itemId = itemEl.dataset.itemId;

                input.value = newQty;
                updateCartTotals();

                const ok = await syncCartItem(itemId, newQty);
                if (!ok) {
                    input.value = newQty - 1;
                    updateCartTotals();
                }
            });
        });

        // ── Quantity decrease ──
        document.querySelectorAll('.decrease-qty').forEach(btn => {
            btn.addEventListener('click', async function () {
                const itemEl = this.closest('.cart-item');
                const input = itemEl.querySelector('.quantity-input');
                const oldQty = parseInt(input.value);
                if (oldQty <= 1) return;

                const newQty = oldQty - 1;
                const itemId = itemEl.dataset.itemId;

                input.value = newQty;
                updateCartTotals();

                const ok = await syncCartItem(itemId, newQty);
                if (!ok) {
                    input.value = oldQty;
                    updateCartTotals();
                }
            });
        });

        // ── Quantity manual input ──
        document.querySelectorAll('.quantity-input').forEach(input => {
            input.addEventListener('change', async function () {
                const itemEl = this.closest('.cart-item');
                const itemId = itemEl.dataset.itemId;
                let newQty = parseInt(this.value);
                if (isNaN(newQty) || newQty < 1) newQty = 1;
                this.value = newQty;
                updateCartTotals();
                await syncCartItem(itemId, newQty);
            });
        });

        // ── Remove item ──
        document.querySelectorAll('.remove-item').forEach(btn => {
            btn.addEventListener('click', async function () {
                if (!confirm('Remove this item from cart?')) return;

                const itemEl = this.closest('.cart-item');
                const itemId = this.dataset.itemId;

                const ok = await removeCartItem(itemId);
                if (ok) {
                    itemEl.style.transition = 'opacity 0.3s';
                    itemEl.style.opacity = '0';
                    setTimeout(() => {
                        itemEl.remove();
                        updateCartTotals();
                        checkEmptyCart();
                    }, 300);
                } else {
                    alert('Failed to remove item. Please try again.');
                }
            });
        });

        // ── Check empty cart ──
        function checkEmptyCart() {
            const items = document.querySelectorAll('.cart-item');
            if (items.length === 0) {
                location.reload();
            }
        }

        // ── Promo code ──
        document.getElementById('applyPromoBtn').addEventListener('click', async function () {
            const codeInput = document.getElementById('promoCodeInput');
            const code = codeInput.value.trim();
            if (!code) { alert('Please enter a promo code'); return; }

            try {
                const res = await fetch('/Checkout/ApplyPromoCode', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ code })
                });
                const data = await res.json();
                if (data.success) {
                    promoDiscount = data.discount;
                    updateCartTotals();
                    alert(data.message);
                } else {
                    promoDiscount = 0;
                    updateCartTotals();
                    alert(data.message);
                }
            } catch (err) {
                console.error('Promo code error:', err);
                alert('Failed to apply promo code.');
            }
        });
    </script>
}