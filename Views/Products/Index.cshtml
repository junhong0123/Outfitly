@using Outfitly.Models
@model ProductListViewModel
@{
    ViewData["Title"] = "Shop";
}

<!-- Main Content -->
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <!-- Top Bar: Filter Button + Sort -->
    <div class="flex justify-between items-center mb-8">
        <button id="filterToggle" class="flex items-center gap-2 text-sm text-black border border-gray-300 px-5 py-2.5 hover:bg-gray-50 transition rounded">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z" />
            </svg>
            <span>Filters</span>
            @{
                int activeFilterCount = 0;
                if (!string.IsNullOrEmpty(Model.SelectedCategory)) activeFilterCount++;
                if (!string.IsNullOrEmpty(Model.SelectedSize)) activeFilterCount++;
                if (!string.IsNullOrEmpty(Model.SelectedColor)) activeFilterCount++;
                if (Model.MinPrice.HasValue) activeFilterCount++;
                if (Model.MaxPrice.HasValue) activeFilterCount++;
            }
            @if (activeFilterCount > 0)
            {
                <span id="filterCount" class="bg-black text-white text-xs rounded-full w-5 h-5 flex items-center justify-center">@activeFilterCount</span>
            }
            else
            {
                <span id="filterCount" class="hidden bg-black text-white text-xs rounded-full w-5 h-5 flex items-center justify-center">0</span>
            }
        </button>

        <div class="flex items-center gap-4">
            <p class="text-sm text-gray-600 hidden sm:block">
                <span class="font-medium text-black">@Model.TotalCount</span> products
            </p>
            @{
                var sortOptions = new[] {
                    ("featured", "Featured"),
                    ("newest", "Newest"),
                    ("price-low", "Price: Low to High"),
                    ("price-high", "Price: High to Low"),
                    ("popular", "Most Popular")
                };
            }
            <select id="sortSelect" class="text-sm border border-gray-300 rounded px-4 py-2.5 focus:outline-none focus:border-black bg-white">
                @foreach (var (val, label) in sortOptions)
                {
                    if (Model.SortBy == val)
                    {
                        <option value="@val" selected>@label</option>
                    }
                    else
                    {
                        <option value="@val">@label</option>
                    }
                }
            </select>
        </div>
    </div>

    <!-- Products Grid -->
    @if (Model.Products != null && Model.Products.Any())
    {
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6 md:gap-8">
            @foreach (var product in Model.Products)
            {
                <a asp-area="" asp-controller="Products" asp-action="Details" asp-route-id="@product.Id"
                   class="group cursor-pointer product-card">
                    <div class="bg-gray-100 aspect-[3/4] mb-3 relative overflow-hidden">
                        @{
                            var firstImage = product.ImageUrls?.FirstOrDefault();
                            var hasRealImage = !string.IsNullOrEmpty(firstImage) && !firstImage.Contains("placehold.co");
                        }
                        @if (hasRealImage)
                        {
                            <img src="@firstImage" alt="@product.Name"
                                 class="absolute inset-0 w-full h-full object-cover"
                                 onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
                            <div class="absolute inset-0 items-center justify-center flex-col gap-2 hidden">
                                <svg class="w-10 h-10 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                                </svg>
                                <span class="text-gray-400 text-xs text-center px-4">@product.Name</span>
                            </div>
                        }
                        else
                        {
                            <div class="absolute inset-0 flex items-center justify-center flex-col gap-2">
                                <svg class="w-10 h-10 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                                </svg>
                                <span class="text-gray-400 text-xs text-center px-4">@product.Name</span>
                            </div>
                        }
                        <div class="absolute inset-0 bg-black bg-opacity-0 group-hover:bg-opacity-5 transition duration-300"></div>
                    </div>
                    <h3 class="text-sm font-light text-black mb-1">@product.Name</h3>
                    <p class="text-xs text-gray-600">$@product.Price.ToString("F2")</p>
                </a>
            }
        </div>
    }
    else
    {
        <div class="text-center py-20">
            <svg class="w-16 h-16 text-gray-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
            </svg>
            <p class="text-gray-500 text-lg mb-2">No products found</p>
            <p class="text-gray-400 text-sm">Try adjusting your filters or search criteria.</p>
        </div>
    }

    <!-- Pagination -->
    @if (Model.TotalPages > 1)
    {
        <div class="mt-16 flex justify-center">
            <nav class="flex items-center gap-2">
                @{
                    // Helper to build a URL preserving all current query params
                    string BuildPageUrl(int page)
                    {
                        var queryParams = new List<string>();
                        if (!string.IsNullOrEmpty(Model.SelectedCategory)) queryParams.Add($"category={Uri.EscapeDataString(Model.SelectedCategory)}");
                        if (!string.IsNullOrEmpty(Model.SelectedSize)) queryParams.Add($"size={Uri.EscapeDataString(Model.SelectedSize)}");
                        if (!string.IsNullOrEmpty(Model.SelectedColor)) queryParams.Add($"color={Uri.EscapeDataString(Model.SelectedColor)}");
                        if (Model.MinPrice.HasValue) queryParams.Add($"minPrice={Model.MinPrice.Value}");
                        if (Model.MaxPrice.HasValue) queryParams.Add($"maxPrice={Model.MaxPrice.Value}");
                        if (Model.SortBy != "featured") queryParams.Add($"sortBy={Uri.EscapeDataString(Model.SortBy)}");
                        queryParams.Add($"pageNumber={page}");
                        queryParams.Add($"pageSize={Model.PageSize}");
                        return "/Products?" + string.Join("&", queryParams);
                    }
                }

                @if (Model.CurrentPage > 1)
                {
                    <a href="@BuildPageUrl(Model.CurrentPage - 1)" class="px-4 py-2 text-sm text-gray-700 hover:text-black">
                        Previous
                    </a>
                }
                else
                {
                    <span class="px-4 py-2 text-sm text-gray-400 cursor-not-allowed">Previous</span>
                }

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    if (i == Model.CurrentPage)
                    {
                        <span class="px-4 py-2 text-sm bg-black text-white">@i</span>
                    }
                    else if (i == 1 || i == Model.TotalPages || (i >= Model.CurrentPage - 1 && i <= Model.CurrentPage + 1))
                    {
                        <a href="@BuildPageUrl(i)" class="px-4 py-2 text-sm text-gray-700 hover:text-black hover:bg-gray-100">@i</a>
                    }
                    else if (i == Model.CurrentPage - 2 || i == Model.CurrentPage + 2)
                    {
                        <span class="px-4 py-2 text-sm text-gray-400">...</span>
                    }
                }

                @if (Model.CurrentPage < Model.TotalPages)
                {
                    <a href="@BuildPageUrl(Model.CurrentPage + 1)" class="px-4 py-2 text-sm text-gray-700 hover:text-black">
                        Next
                    </a>
                }
                else
                {
                    <span class="px-4 py-2 text-sm text-gray-400 cursor-not-allowed">Next</span>
                }
            </nav>
        </div>
    }
</div>

<!-- Filter Sidebar (Slide-in Panel) -->
<div id="filterPanel" class="fixed inset-y-0 left-0 w-80 bg-white shadow-2xl transform -translate-x-full transition-transform duration-300 ease-in-out z-50 overflow-y-auto">
    <div class="p-6">
        <!-- Header -->
        <div class="flex items-center justify-between mb-8 pb-4 border-b border-gray-200">
            <h2 class="text-lg font-medium text-black">Filters</h2>
            <button id="closeFilter" class="text-gray-600 hover:text-black">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </button>
        </div>

        <!-- Category Filter -->
        <div class="mb-8 pb-8 border-b border-gray-200">
            <h3 class="text-xs font-medium text-black mb-4 tracking-wide">CATEGORY</h3>
            <div class="space-y-3">
                @{
                    var categories = new[] { "Tops", "Bottoms", "Outerwear", "Dresses", "Footwear", "Accessories" };
                }
                @foreach (var cat in categories)
                {
                    <label class="flex items-center cursor-pointer group">
                        <input type="radio" name="category" value="@cat"
                               class="w-4 h-4 border-gray-300 text-black focus:ring-black filter-category"
                               @(Model.SelectedCategory?.Equals(cat, StringComparison.OrdinalIgnoreCase) == true ? "checked" : "")>
                        <span class="ml-3 text-sm text-gray-700 group-hover:text-black">@cat</span>
                    </label>
                }
            </div>
        </div>

        <!-- Price Range Filter -->
        <div class="mb-8 pb-8 border-b border-gray-200">
            <h3 class="text-xs font-medium text-black mb-4 tracking-wide">PRICE RANGE</h3>
            <div class="space-y-4">
                <div>
                    <input type="range" min="0" max="500" value="@(Model.MaxPrice ?? 500)" id="priceRange"
                           class="w-full h-1.5 bg-gray-200 rounded-lg appearance-none cursor-pointer accent-black">
                    <div class="flex justify-between mt-3">
                        <span class="text-xs text-gray-600">$0</span>
                        <span class="text-sm text-black font-medium" id="priceValue">$@(Model.MaxPrice ?? 500)</span>
                        <span class="text-xs text-gray-600">$500</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Size Filter -->
        <div class="mb-8 pb-8 border-b border-gray-200">
            <h3 class="text-xs font-medium text-black mb-4 tracking-wide">SIZE</h3>
            <div class="space-y-3">
                @{
                    var sizes = new[] { "XS", "S", "M", "L", "XL" };
                }
                @foreach (var sz in sizes)
                {
                    <label class="flex items-center cursor-pointer group">
                        <input type="radio" name="size" value="@sz"
                               class="w-4 h-4 border-gray-300 text-black focus:ring-black filter-size"
                               @(Model.SelectedSize?.Equals(sz, StringComparison.OrdinalIgnoreCase) == true ? "checked" : "")>
                        <span class="ml-3 text-sm text-gray-700 group-hover:text-black">@sz</span>
                    </label>
                }
            </div>
        </div>

        <!-- Color Filter -->
        <div class="mb-8">
            <h3 class="text-xs font-medium text-black mb-4 tracking-wide">COLOR</h3>
            <div class="flex flex-wrap gap-3">
                @{
                    var colorOptions = new (string Name, string BgClass)[]
                    {
                        ("Black", "bg-black"),
                        ("White", "bg-white"),
                        ("Gray", "bg-gray-500"),
                        ("Blue", "bg-blue-600"),
                        ("Red", "bg-red-600"),
                        ("Green", "bg-green-700"),
                        ("Yellow", "bg-yellow-600"),
                        ("Pink", "bg-pink-400"),
                        ("Navy", "bg-blue-900"),
                        ("Brown", "bg-yellow-700")
                    };
                }
                @foreach (var co in colorOptions)
                {
                    var isSelected = Model.SelectedColor?.Equals(co.Name, StringComparison.OrdinalIgnoreCase) == true;
                    <button class="w-10 h-10 rounded-full @co.BgClass border-2 border-gray-300 hover:border-black transition color-swatch @(isSelected ? "ring-2 ring-black ring-offset-2" : "")"
                            data-color="@co.Name" title="@co.Name"></button>
                }
            </div>
        </div>

        <!-- Action Buttons -->
        <div class="flex gap-3 pt-6 border-t border-gray-200">
            <button id="clearAllFilters" class="flex-1 border border-gray-300 text-black px-4 py-3 text-sm hover:bg-gray-50 transition">
                Clear All
            </button>
            <button id="applyFilters" class="flex-1 bg-black text-white px-4 py-3 text-sm hover:bg-gray-800 transition">
                Apply Filters
            </button>
        </div>
    </div>
</div>

<!-- Overlay (Background) -->
<div id="filterOverlay" class="hidden fixed inset-0 bg-black bg-opacity-50 z-40 transition-opacity duration-300"></div>

@section Scripts {
    <script>
        const filterPanel = document.getElementById('filterPanel');
        const filterOverlay = document.getElementById('filterOverlay');
        const filterToggle = document.getElementById('filterToggle');
        const closeFilter = document.getElementById('closeFilter');
        const filterCount = document.getElementById('filterCount');

        // Open filter panel
        filterToggle.addEventListener('click', function() {
            filterPanel.classList.remove('-translate-x-full');
            filterOverlay.classList.remove('hidden');
            document.body.style.overflow = 'hidden';
        });

        // Close filter panel
        function closeFilterPanel() {
            filterPanel.classList.add('-translate-x-full');
            filterOverlay.classList.add('hidden');
            document.body.style.overflow = 'auto';
        }

        closeFilter.addEventListener('click', closeFilterPanel);
        filterOverlay.addEventListener('click', closeFilterPanel);

        // Price range slider
        const priceRange = document.getElementById('priceRange');
        const priceValue = document.getElementById('priceValue');

        priceRange.addEventListener('input', function() {
            priceValue.textContent = '$' + this.value;
        });

        // Color selection (single-select)
        document.querySelectorAll('.color-swatch').forEach(button => {
            button.addEventListener('click', function() {
                // Remove selection from all
                document.querySelectorAll('.color-swatch').forEach(b => {
                    b.classList.remove('ring-2', 'ring-black', 'ring-offset-2');
                });
                // Toggle on clicked
                this.classList.add('ring-2', 'ring-black', 'ring-offset-2');
            });
        });

        // Clear all filters
        document.getElementById('clearAllFilters').addEventListener('click', function() {
            document.querySelectorAll('.filter-category').forEach(r => r.checked = false);
            document.querySelectorAll('.filter-size').forEach(r => r.checked = false);
            document.querySelectorAll('.color-swatch').forEach(b => {
                b.classList.remove('ring-2', 'ring-black', 'ring-offset-2');
            });
            priceRange.value = 500;
            priceValue.textContent = '$500';
        });

        // Apply filters — build URL and navigate
        document.getElementById('applyFilters').addEventListener('click', function() {
            const params = new URLSearchParams();

            // Category
            const selectedCategory = document.querySelector('.filter-category:checked');
            if (selectedCategory) params.set('category', selectedCategory.value);

            // Size
            const selectedSize = document.querySelector('.filter-size:checked');
            if (selectedSize) params.set('size', selectedSize.value);

            // Color
            const selectedColor = document.querySelector('.color-swatch.ring-2');
            if (selectedColor) params.set('color', selectedColor.dataset.color);

            // Price range
            const maxPrice = parseInt(priceRange.value);
            if (maxPrice < 500) params.set('maxPrice', maxPrice);

            // Preserve current sort
            const currentSort = document.getElementById('sortSelect').value;
            if (currentSort && currentSort !== 'featured') params.set('sortBy', currentSort);

            // Reset to page 1 when filters change
            window.location.href = '/Products?' + params.toString();
        });

        // Sort functionality — navigate with updated sort
        document.getElementById('sortSelect').addEventListener('change', function() {
            const params = new URLSearchParams(window.location.search);
            if (this.value && this.value !== 'featured') {
                params.set('sortBy', this.value);
            } else {
                params.delete('sortBy');
            }
            // Reset to page 1 when sort changes
            params.delete('pageNumber');
            window.location.href = '/Products?' + params.toString();
        });
    </script>
}