@model Outfitly.Models.SavedAddress

@{
    ViewData["Title"] = "My Addresses";
}

<!-- Page Header -->
<div class="bg-white border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <h1 class="text-3xl md:text-4xl font-light text-black mb-2">My Account</h1>
        <p class="text-sm text-gray-600">Manage your profile and shipping address</p>
    </div>
</div>

<!-- Dashboard Content -->
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-12">

    <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">

        <!-- Left Sidebar: Navigation -->
        <aside class="lg:col-span-1">
            <nav class="bg-white border border-gray-200 rounded overflow-hidden">
                <a asp-area="" asp-controller="Account" asp-action="Dashboard"
                   class="block px-4 py-3 text-sm text-gray-700 hover:bg-gray-50 hover:text-black border-l-2 border-transparent">
                    Dashboard
                </a>
                <a asp-area="" asp-controller="Account" asp-action="Orders"
                   class="block px-4 py-3 text-sm text-gray-700 hover:bg-gray-50 hover:text-black border-l-2 border-transparent">
                    Orders
                </a>
                <a asp-area="" asp-controller="Account" asp-action="Addresses"
                   class="block px-4 py-3 text-sm bg-gray-50 text-black border-l-2 border-black font-medium">
                    Addresses
                </a>
                <a asp-area="" asp-controller="Account" asp-action="Settings"
                   class="block px-4 py-3 text-sm text-gray-700 hover:bg-gray-50 hover:text-black border-l-2 border-transparent border-t border-gray-200">
                    Settings
                </a>
                <a href="#" onclick="return confirm('Are you sure you want to logout?')"
                   class="block px-4 py-3 text-sm text-red-600 hover:bg-red-50 border-l-2 border-transparent border-t border-gray-200">
                    Logout
                </a>
            </nav>
        </aside>

        <!-- Main Content -->
        <main class="lg:col-span-3">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="mb-6 bg-green-50 border border-green-200 text-green-800 px-4 py-3 rounded text-sm relative" role="alert">
                    <span class="block sm:inline">@TempData["SuccessMessage"]</span>
                </div>
            }

            <div class="bg-white border border-gray-200 rounded p-6 lg:p-8">
                <h2 class="text-xl font-light text-black mb-6">Profile & Address Information</h2>
                
                <form asp-action="Addresses" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-sm text-red-600 mb-4"></div>
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
                        <div>
                            <label asp-for="FirstName" class="block text-sm font-medium text-gray-700 mb-1">First Name</label>
                            <input asp-for="FirstName" class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-black focus:border-black text-sm" />
                            <span asp-validation-for="FirstName" class="text-xs text-red-600 mt-1"></span>
                        </div>
                        <div>
                            <label asp-for="LastName" class="block text-sm font-medium text-gray-700 mb-1">Last Name</label>
                            <input asp-for="LastName" class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-black focus:border-black text-sm" />
                            <span asp-validation-for="LastName" class="text-xs text-red-600 mt-1"></span>
                        </div>
                        <div class="md:col-span-2">
                            <label asp-for="Email" class="block text-sm font-medium text-gray-700 mb-1">Email Address</label>
                            <input asp-for="Email" type="email" class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-black focus:border-black text-sm" />
                            <span asp-validation-for="Email" class="text-xs text-red-600 mt-1"></span>
                        </div>
                        <div class="md:col-span-2">
                            <label asp-for="Phone" class="block text-sm font-medium text-gray-700 mb-1">Phone Number</label>
                            <input asp-for="Phone" type="tel" class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-black focus:border-black text-sm" />
                            <span asp-validation-for="Phone" class="text-xs text-red-600 mt-1"></span>
                        </div>
                    </div>

                    <h3 class="text-lg font-medium text-black mb-4">Shipping Address</h3>
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="md:col-span-2">
                            <label asp-for="AddressLine1" class="block text-sm font-medium text-gray-700 mb-1">Address Line 1</label>
                            <input asp-for="AddressLine1" class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-black focus:border-black text-sm" placeholder="Street address or P.O. Box" />
                            <span asp-validation-for="AddressLine1" class="text-xs text-red-600 mt-1"></span>
                        </div>
                        <div class="md:col-span-2">
                            <label asp-for="AddressLine2" class="block text-sm font-medium text-gray-700 mb-1">Address Line 2 (Optional)</label>
                            <input asp-for="AddressLine2" class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-black focus:border-black text-sm" placeholder="Apartment, suite, unit, building, floor, etc." />
                            <span asp-validation-for="AddressLine2" class="text-xs text-red-600 mt-1"></span>
                        </div>
                        <div>
                            <label asp-for="City" class="block text-sm font-medium text-gray-700 mb-1">City</label>
                            <input asp-for="City" class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-black focus:border-black text-sm" />
                            <span asp-validation-for="City" class="text-xs text-red-600 mt-1"></span>
                        </div>
                        <div>
                            <label asp-for="State" class="block text-sm font-medium text-gray-700 mb-1">State / Province</label>
                            <input asp-for="State" class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-black focus:border-black text-sm" />
                            <span asp-validation-for="State" class="text-xs text-red-600 mt-1"></span>
                        </div>
                        <div>
                            <label asp-for="Zip" class="block text-sm font-medium text-gray-700 mb-1">ZIP / Postal Code</label>
                            <input asp-for="Zip" class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-black focus:border-black text-sm" />
                            <span asp-validation-for="Zip" class="text-xs text-red-600 mt-1"></span>
                        </div>
                        <div>
                            <label asp-for="Country" class="block text-sm font-medium text-gray-700 mb-1">Country</label>
                            <select asp-for="Country" class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-black focus:border-black text-sm">
                                <option value="">Select a country</option>
                                <option value="United States">United States</option>
                                <option value="Canada">Canada</option>
                                <option value="United Kingdom">United Kingdom</option>
                                <option value="Australia">Australia</option>
                                <option value="Germany">Germany</option>
                                <option value="France">France</option>
                            </select>
                            <span asp-validation-for="Country" class="text-xs text-red-600 mt-1"></span>
                        </div>
                    </div>

                    <div class="mt-8 flex justify-end">
                        <button type="submit" class="bg-black text-white px-8 py-3 text-sm tracking-wide hover:bg-gray-800 transition rounded focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-black">
                            SAVE CHANGES
                        </button>
                    </div>
                </form>
            </div>
        </main>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
