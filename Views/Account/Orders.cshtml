@model List<Order>
@{
    ViewData["Title"] = "Order History";
}

<!-- Page Header -->
<div class="bg-white border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <h1 class="text-3xl md:text-4xl font-light text-black">Order History</h1>
    </div>
</div>

<!-- Order History Content -->
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-12">

    <!-- Filter Tabs -->
    <div class="flex gap-4 mb-8 overflow-x-auto pb-2 border-b border-gray-200">
        @{
            var currentStatus = ViewBag.CurrentStatus as string ?? "all";
            string GetTabClass(string status) => currentStatus == status
                ? "px-4 py-2 text-sm whitespace-nowrap border-b-2 border-black font-medium text-black -mb-[1px]"
                : "px-4 py-2 text-sm whitespace-nowrap border-b-2 border-transparent text-gray-600 hover:text-black hover:border-gray-300 -mb-[1px]";
        }
        
        <a asp-action="Orders" asp-route-status="all" class="@GetTabClass("all")">
            All Orders
        </a>
        <a asp-action="Orders" asp-route-status="processing" class="@GetTabClass("processing")">
            Processing
        </a>
        <a asp-action="Orders" asp-route-status="shipped" class="@GetTabClass("shipped")">
            Shipped
        </a>
        <a asp-action="Orders" asp-route-status="delivered" class="@GetTabClass("delivered")">
            Delivered
        </a>
        <a asp-action="Orders" asp-route-status="cancelled" class="@GetTabClass("cancelled")">
            Cancelled
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="mb-6 bg-green-50 border border-green-200 text-green-800 px-4 py-3 rounded text-sm relative" role="alert">
            <span class="block sm:inline">@TempData["SuccessMessage"]</span>
        </div>
    }

    <!-- Orders List -->
    <div class="space-y-6">
        @if (Model.Any())
        {
            @foreach (var order in Model)
            {
                var statusColor = order.Status.ToLower() switch
                {
                    "delivered" => "bg-green-100 text-green-800",
                    "shipped" => "bg-blue-100 text-blue-800",
                    "cancelled" => "bg-red-100 text-red-800",
                    "processing" => "bg-amber-100 text-amber-800",
                    _ => "bg-gray-100 text-gray-800"
                };

                <div class="order-card bg-white border border-gray-200 rounded overflow-hidden">
                    <!-- Order Header -->
                    <div class="bg-gray-50 px-6 py-4 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 border-b border-gray-200">
                        <div class="flex flex-wrap items-center gap-6">
                            <div>
                                <p class="text-xs font-semibold text-gray-500 mb-1 tracking-wider">ORDER NUMBER</p>
                                <p class="text-sm font-medium text-black">@order.OrderNumber</p>
                            </div>
                            <div>
                                <p class="text-xs font-semibold text-gray-500 mb-1 tracking-wider">DATE PLACED</p>
                                <p class="text-sm text-black">@order.OrderDate.ToString("MMM dd, yyyy")</p>
                            </div>
                            <div>
                                <p class="text-xs font-semibold text-gray-500 mb-1 tracking-wider">TOTAL AMOUNT</p>
                                <p class="text-sm font-medium text-black">@order.Total.ToString("C")</p>
                            </div>
                        </div>
                        <div>
                            <span class="inline-flex items-center px-3 py-1 @statusColor text-xs font-medium rounded-full">
                                @order.Status
                            </span>
                        </div>
                    </div>

                    <!-- Order Items -->
                    <div class="px-6 py-4 divide-y divide-gray-100">
                        @foreach (var item in order.OrderItems)
                        {
                            <div class="py-4 first:pt-0 last:pb-0 flex gap-4">
                                <div class="w-20 h-24 bg-gray-100 rounded overflow-hidden flex-shrink-0 border border-gray-200">
                                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                                    {
                                        <img src="@item.ImageUrl" alt="@item.ProductName" class="w-full h-full object-cover" />
                                    }
                                    else
                                    {
                                        <div class="w-full h-full flex items-center justify-center bg-gray-50">
                                            <svg class="h-8 w-8 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                            </svg>
                                        </div>
                                    }
                                </div>
                                <div class="flex-grow flex flex-col justify-between">
                                    <div>
                                        <div class="flex justify-between items-start">
                                            <h3 class="text-sm font-medium text-black line-clamp-2 hover:text-gray-600 transition">
                                                <a asp-controller="Products" asp-action="Details" asp-route-id="@item.ProductId">@item.ProductName</a>
                                            </h3>
                                            <p class="text-sm font-medium text-black">@item.TotalPrice.ToString("C")</p>
                                        </div>
                                        <div class="mt-1 flex items-center gap-3 text-xs text-gray-500">
                                            @if (!string.IsNullOrEmpty(item.Color))
                                            {
                                                <span class="flex items-center gap-1">Color: <span class="text-gray-900 font-medium">@item.Color</span></span>
                                            }
                                            @if (!string.IsNullOrEmpty(item.Size))
                                            {
                                                <span class="flex items-center gap-1">Size: <span class="text-gray-900 font-medium">@item.Size</span></span>
                                            }
                                            <span class="flex items-center gap-1 border-l border-gray-300 pl-3">Qty: <span class="text-gray-900 font-medium">@item.Quantity</span></span>
                                        </div>
                                    </div>
                                    
                                    @if (order.Status.ToLower() == "delivered")
                                    {
                                        <div class="mt-2 flex justify-end">
                                            <a asp-action="WriteReview" asp-route-productId="@item.ProductId" class="text-xs text-black border-b border-black hover:text-gray-600 hover:border-gray-600 pb-0.5 transition">
                                                Write Review
                                            </a>
                                        </div>
                                    }
                                </div>
                            </div>
                        }

                        @if (order.Status.ToLower() == "shipped" && !string.IsNullOrEmpty(order.TrackingNumber))
                        {
                            <!-- Tracking Info -->
                            <div class="mt-4 bg-blue-50 border border-blue-200 rounded p-4">
                                <div class="flex items-start gap-3">
                                    <svg class="w-5 h-5 text-blue-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4" />
                                    </svg>
                                    <div class="flex-grow">
                                        <p class="text-xs text-blue-900 font-medium mb-1">In Transit</p>
                                        @if (order.DeliveredDate.HasValue)
                                        {
                                            <p class="text-xs text-blue-800 mb-2">Expected delivery: @order.DeliveredDate.Value.ToString("MMM dd, yyyy")</p>
                                        }
                                        <p class="text-xs text-blue-700 font-mono tracking-tight bg-blue-100 px-2 py-0.5 rounded inline-block">@order.TrackingNumber</p>
                                    </div>
                                </div>
                            </div>
                        }

                        @if (order.Status.ToLower() == "cancelled")
                        {
                            <!-- Cancelled Info -->
                            <div class="mt-4 bg-red-50 border border-red-200 rounded p-4">
                                <div class="flex items-start gap-3">
                                    <svg class="w-5 h-5 text-red-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                                    </svg>
                                    <div>
                                        <p class="text-xs text-red-900 font-medium mb-1">Order Cancelled</p>
                                        <p class="text-xs text-red-800">This order was cancelled. Any charges have been refunded.</p>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>

                    <!-- Order Actions -->
                    <div class="px-6 py-4 bg-gray-50 border-t border-gray-200 flex flex-col sm:flex-row gap-3">
                        <a asp-action="OrderDetails" asp-route-id="@order.Id" class="flex-1 text-center border border-gray-300 bg-white text-black py-2 text-sm font-medium hover:bg-gray-50 transition rounded shadow-sm">
                            View Order Details
                        </a>
                        
                        @if (order.Status.ToLower() == "processing" || order.Status.ToLower() == "pending")
                        {
                            <button onclick="cancelOrder(@order.Id)" class="flex-1 text-center border border-red-300 text-red-700 bg-white py-2 text-sm font-medium hover:bg-red-50 transition rounded shadow-sm">
                                Cancel Order
                            </button>
                        }
                        else if (order.Status.ToLower() == "shipped")
                        {
                            <button onclick="trackOrder(@order.Id)" class="flex-1 text-center border border-blue-300 text-blue-700 bg-white py-2 text-sm font-medium hover:bg-blue-50 transition rounded shadow-sm">
                                Track Delivery
                            </button>
                        }

                        <form asp-action="BuyAgain" method="post" class="flex-1 flex">
                            <input type="hidden" name="orderId" value="@order.Id" />
                            <button type="submit" class="w-full text-center bg-black border border-transparent text-white py-2 text-sm font-medium hover:bg-gray-800 transition rounded shadow-sm">
                                Buy Again
                            </button>
                        </form>
                    </div>
                </div>
            }
        }
        else
        {
            <!-- Empty State -->
            <div class="text-center py-24 bg-white border border-gray-200 rounded border-dashed">
                <div class="w-20 h-20 bg-gray-50 rounded-full flex items-center justify-center mx-auto mb-6">
                    <svg class="w-10 h-10 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
                    </svg>
                </div>
                <h2 class="text-2xl font-light text-black mb-2">No orders found</h2>
                <p class="text-sm text-gray-500 mb-8 max-w-sm mx-auto">You haven't placed any orders matching this status yet.</p>
                <a asp-area="" asp-controller="Products" asp-action="Index"
                   class="inline-block bg-black text-white px-8 py-3 text-sm font-medium tracking-wide hover:bg-gray-800 transition rounded shadow-sm">
                    START SHOPPING
                </a>
            </div>
        }
    </div>

    @if (ViewBag.TotalPages > 1)
    {
        <!-- Pagination -->
        <div class="mt-12 flex justify-center">
            <nav class="flex items-center gap-2">
                @if (ViewBag.CurrentPage > 1)
                {
                    <a asp-action="Orders" asp-route-status="@ViewBag.CurrentStatus" asp-route-page="@(ViewBag.CurrentPage - 1)" 
                       class="px-4 py-2 text-sm text-gray-700 hover:text-black border border-gray-300 rounded hover:bg-gray-50 transition">
                        Previous
                    </a>
                }
                else
                {
                    <button disabled class="px-4 py-2 text-sm text-gray-400 border border-gray-200 rounded cursor-not-allowed">
                        Previous
                    </button>
                }

                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    if (i == ViewBag.CurrentPage)
                    {
                        <span class="px-4 py-2 text-sm bg-black text-white rounded font-medium">@i</span>
                    }
                    else
                    {
                        <a asp-action="Orders" asp-route-status="@ViewBag.CurrentStatus" asp-route-page="@i" 
                           class="px-4 py-2 text-sm text-gray-700 hover:text-black hover:bg-gray-100 rounded transition">
                            @i
                        </a>
                    }
                }

                @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                {
                    <a asp-action="Orders" asp-route-status="@ViewBag.CurrentStatus" asp-route-page="@(ViewBag.CurrentPage + 1)" 
                       class="px-4 py-2 text-sm text-gray-700 hover:text-black border border-gray-300 rounded hover:bg-gray-50 transition">
                        Next
                    </a>
                }
                else
                {
                    <button disabled class="px-4 py-2 text-sm text-gray-400 border border-gray-200 rounded cursor-not-allowed">
                        Next
                    </button>
                }
            </nav>
        </div>
    }
</div>

@section Scripts {
    <script>
        async function cancelOrder(orderId) {
            if (!confirm('Are you sure you want to cancel this order?')) {
                return;
            }

            try {
                const response = await fetch('/Account/CancelOrder', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                    },
                    body: `orderId=${orderId}`
                });

                const data = await response.json();
                if (data.success) {
                    alert(data.message);
                    window.location.reload();
                } else {
                    alert(data.message || 'Failed to cancel order.');
                }
            } catch (error) {
                console.error('Error cancelling order:', error);
                alert('An error occurred. Please try again.');
            }
        }

        async function trackOrder(orderId) {
            try {
                const response = await fetch('/Account/TrackOrder', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                    },
                    body: `orderId=${orderId}`
                });

                const data = await response.json();
                if (data.success) {
                    // In a complete implementation, this would open a modal
                    // For now, we'll just log it and show a simple alert
                    console.log('Tracking info:', data.tracking);
                    alert(`Tracking Number: ${data.tracking.trackingNumber}\nStatus: ${data.tracking.status}\nEstimated Delivery: ${data.tracking.estimatedDelivery}`);
                }
            } catch (error) {
                console.error('Error fetching tracking info:', error);
            }
        }
    </script>
}